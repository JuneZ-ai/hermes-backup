    "relationships": [
      {
        "from": {
          "object": "daily_record",
          "field": "gregorian_date"
        },
        "to": {
          "object": "operation_log",
          "field": "timestamp"
        },
        "type": "one_to_many",
        "label": "时间关联",
        "description": "每天的每日记录可以关联多条搭建日志——当天干了哪些搭建工作",
        "confidence": "high",
        "example": "2026-05-19的每日记录中记录「打通飞书开放平台全部四大API」，对应的搭建日志中有多条该日期的API打通操作"
      },
      {
        "from": {
          "object": "daily_record",
          "field": "gregorian_date"
        },
        "to": {
          "object": "favorite_item",
          "field": "collect_date"
        },
        "type": "one_to_many",
        "label": "收藏关联",
        "description": "每天的每日记录可以关联当天收藏的素材——当天收了哪些好东西",
        "confidence": "medium",
        "note": "需验证日期匹配规则（精确到天还是到毫秒）"
      },
      {
        "from": {
          "object": "favorite_item",
          "field": "title"
        },
        "to": {
          "object": "daily_record",
          "field": "content"
        },
        "type": "textual_reference",
        "label": "引用关联",
        "description": "每日记录中可能引用了收藏素材的内容",
        "confidence": "low",
        "note": "需通过关键词匹配或语义搜索验证。例如：每日记录中提到「入库《定位》」与收藏随想录中《定位》素材存在引用关系"
      },
      {
        "from": {
          "object": "operation_log",
          "field": "domain"
        },
        "to": {
          "object": "favorite_item",
          "field": "category"
        },
        "type": "many_to_many",
        "label": "领域关联",
        "description": "搭建日志的领域（如「知识库基建」）与收藏素材的分类（如「技术/AI」）之间存在隐含映射",
        "confidence": "medium",
        "note": "例如：搭建日志建知识库基建→收藏素材分类技术/AI的文章恰好是相关教程"
      }
    ],

